rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isOwner() {
      return request.auth != null
        && request.auth.token.email == "salahalgarmani@gmail.com"
        && request.auth.token.email_verified == true;
    }

    match /{allPaths=**} {
      allow read, write: if isOwner();
    }
  }
}
